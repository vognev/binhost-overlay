#!/bin/bash

set -e

CHOST="${CHOST:-x86_64-pc-linux-gnu}"

TARGET_PKG="$1"

if [ -z "${TARGET_PKG}" ]; then
    echo "Error: specify a package to build (e.g., $0 net-misc/networkmanager)"
    exit 1
fi

# todo: depclean all except bdeps of $1

"${CHOST}-emerge" --depclean --with-bdeps=y

"${CHOST}-emerge" -v1 --onlydeps --with-bdeps=y "${TARGET_PKG}"

FEATURES="-gtbinpkg" \
"${CHOST}-emerge" -v1 --buildpkgonly --usepkg=n "${TARGET_PKG}"
